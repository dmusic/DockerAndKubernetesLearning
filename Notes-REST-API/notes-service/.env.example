# =============================================================================
# notes-service — Environment Variable Contract
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# All variables are validated at startup by Zod in src/config/env.js.
# A missing required variable will cause the process to exit immediately
# with a descriptive error before any server or DB connection is attempted.
# =============================================================================


# -----------------------------------------------------------------------------
# RUNTIME
# -----------------------------------------------------------------------------

# Node.js environment.
# Controls log format (colorised in development, JSON in production/test),
# morgan request logging (disabled in test), and error response verbosity.
# Allowed values: development | test | production
NODE_ENV=development

# Port that Express listens on INSIDE the container.
# This port is NOT exposed to the host — all traffic arrives through nginx.
# Change only if you have a specific port conflict during standalone dev.
PORT=3000


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Full MongoDB connection string.
# notes-service has its OWN MongoDB instance (notes-mongodb).
# It must never point to notebooks-mongodb.
#   Integrated stack : mongodb://notes-mongodb:27017
#   Standalone dev   : mongodb://localhost:27017
#   Atlas            : mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_URI=mongodb://notes-mongodb:27017

# Name of the MongoDB database to use.
# Mongoose passes this as the `dbName` option — it does NOT need to be
# embedded in MONGO_URI.
#   development : notes_dev
#   test        : notes_test   (use a separate DB so tests never touch dev data)
#   production  : notes_prod
MONGO_DB_NAME=notes_dev


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# Secret key used to sign and verify JSON Web Tokens.
# MUST be at least 32 characters long — startup validation will reject shorter values.
# Generate a strong value with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Never reuse this value between environments.
JWT_SECRET=replace_this_with_a_random_32_plus_character_secret

# How long issued JWTs remain valid.
# Uses the ms / jsonwebtoken duration string format.
# Examples: 15m  1h  7d  30d
# Shorter values improve security but require more frequent re-authentication.
JWT_EXPIRES_IN=7d


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Minimum log level that Winston will output.
# Messages below this level are silently dropped.
# Hierarchy (lowest → highest): debug → info → warn → error
# Recommended values:
#   development : debug   (see everything)
#   test        : error   (keep test output clean)
#   production  : info    (info + warn + error)
LOG_LEVEL=debug


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Allowed CORS origin(s) for the Access-Control-Allow-Origin header.
# Comma-separated list for multiple origins: http://localhost:5173,https://app.example.com
# Use * only in development — it is NOT acceptable in production.
# In production set this to the exact frontend origin(s).
CORS_ORIGIN=http://localhost:5173


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Duration of the rate-limit window, in minutes.
# All requests from a single IP within this window are counted together.
RATE_LIMIT_WINDOW=15

# Maximum number of requests allowed per IP per window before returning 429.
# Requests that exceed this limit receive a standard error response.
RATE_LIMIT_MAX=100


# -----------------------------------------------------------------------------
# CROSS-SERVICE — notebooks-service integration
# -----------------------------------------------------------------------------

# Base URL of notebooks-service used for notebook existence validation.
#
# When a note is created with a notebookId, this service calls:
#   GET <NOTEBOOKS_SERVICE_URL>/api/v1/notebooks/:id
# to verify the notebook exists before saving the note.
#
# If the call times out (> 3 000 ms) or notebooks-service is unreachable,
# the note is saved with the unverified notebookId (graceful degradation)
# and a warn-level log entry is emitted. No error is returned to the caller.
#
# Value in each context:
#   Integrated stack (root compose.yaml) : injected automatically as http://notebooks-api:3000
#                                          — do not set manually when using the root compose
#   Standalone dev (notes-service only)  : http://localhost:<notebooks-service-port>
#                                          or point to a mock server / WireMock instance
#   Test environment                     : http://localhost:9999  (mock server or nock intercept)
#
# This variable is optional — if omitted the default http://notebooks-api:3000 is used.
NOTEBOOKS_SERVICE_URL=http://notebooks-api:3000
