# MongoDB Root Credentials (for Docker)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=adminpassword

# MongoDB Application Credentials
KEY_VALUE_STORE_USER=appuser
KEY_VALUE_STORE_PASSWORD=apppassword

# MongoDB Connection Settings
# For local development without auth: leave MONGODB_USER and MONGODB_PASSWORD empty
# For Docker with auth: set MONGODB_USER and MONGODB_PASSWORD
MONGODB_USER=appuser
MONGODB_PASSWORD=apppassword
MONGODB_HOST=localhost
MONGODB_PORT=27017

# Database name
DB_NAME=keyValueStore
KEY_VALUE_STORE_DB=keyValueStore

# Server port
PORT=3000
